{
  "$schema": "https://glotfile.dev/schema/v1.json",
  "config": {
    "autoExport": true,
    "format": {
      "finalNewline": true,
      "indent": 2,
      "sortKeys": true
    },
    "localeInstructions": {
      "de": "Use the formal Sie; prefer 'düngen' for feeding a plant.",
      "es": "Use a friendly, informal tú.",
      "fr": "Use vouvoiement; keep a warm, encouraging tone."
    },
    "locales": [
      "en",
      "de",
      "es",
      "fr"
    ],
    "outputs": [
      {
        "adapter": "i18next-json",
        "path": "public/locales/{locale}/translation.json"
      }
    ],
    "projectContext": "Sprout is a houseplant-care app; treat 'feed' as giving a plant fertilizer, never as a social-media feed.",
    "sourceLocale": "en",
    "spelling": {
      "customWords": [
        "Sprout",
        "houseplant",
        "repot"
      ]
    }
  },
  "glossary": [
    {
      "doNotTranslate": true,
      "notes": "Brand name. Never translate.",
      "term": "Sprout"
    },
    {
      "doNotTranslate": true,
      "notes": "Paid tier. Keep the full name verbatim in every language.",
      "term": "Sprout Pro"
    },
    {
      "notes": "In Sprout, 'feed' means fertilizing a plant — never a content feed. Translate to the gardening sense (fr: nourrir/fertiliser, de: düngen).",
      "term": "feed"
    },
    {
      "notes": "Forced UI label for the light-level setting so every locale matches the design.",
      "term": "Light",
      "translations": {
        "de": "Licht",
        "es": "Luz",
        "fr": "Luminosité"
      }
    }
  ],
